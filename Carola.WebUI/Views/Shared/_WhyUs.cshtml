@model List<Carola.DtoLayer.WhyUsDtos.ResultWhyUsDto>

<section class="divider">
    <div class="container">
        <div class="border-divider"></div>
    </div>
</section>

<section class="why-chooseus-section pt_120 pb_90">
    <div class="shape-three"><img src="~/site-assets/images/shape/shape-3.png" alt=""></div>
    <div class="shape-four"><img src="~/site-assets/images/shape/shape-4.png" alt=""></div>
    <div class="container">
        <div class="row">

            <div class="col-xl-4 col-lg-4 col-md-12 col-sm-12">
                <div class="section-title mb_60">
                    <span class="sub-title">We Are the Best</span>
                    <h2 class="title">Sürüş özgürlüğünüzü <br>kendi kararlarınızla yaşayın</h2>
                </div>
            </div>

            @foreach (var item in Model)
            {
                <div class="col-xl-4 col-lg-4 col-md-6 col-sm-12">
                    <div class="why-chooseus-block">
                        <div class="why-chooseus-icon light">
                            <img src="@item.IconUrl" alt="@item.Title"
                                 onerror="this.style.display='none'"
                                 style="width:48px;height:48px;object-fit:contain">
                        </div>
                        <h5 class="why-chooseus-title">@item.Title</h5>
                        <p class="why-chooseus-text">@item.Description</p>
                    </div>
                </div>
            }

        </div>
    </div>
</section>