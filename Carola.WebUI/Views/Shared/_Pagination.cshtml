@model dynamic


@{
    var current = (int)Model.PageNumber;
    var total = (int)Model.TotalPages;
    var hasPrev = (bool)Model.HasPrevious;
    var hasNext = (bool)Model.HasNext;

    var currentQuery = ViewContext.HttpContext.Request.Query
        .Where(q => q.Key != "pageNumber")
        .ToDictionary(q => q.Key, q => q.Value.ToString());

    string PageUrl(int p)
    {
        var dict = new Dictionary<string, string>(currentQuery) { ["pageNumber"] = p.ToString() };
        var qs = string.Join("&", dict.Where(kv => !string.IsNullOrEmpty(kv.Value))
                                       .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value)}"));
        return $"?{qs}";
    }
}

@if (total > 1)
{
    <nav aria-label="Sayfalama" class="mt-5">
        <ul class="pagination justify-content-center">

            @if (hasPrev)
            {
                <li class="page-item">
                    <a class="page-link" href="@PageUrl(current - 1)">
                        <i class="fas fa-angle-left"></i>
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link"><i class="fas fa-angle-left"></i></span>
                </li>
            }

            @for (int i = 1; i <= total; i++)
            {
                if (i == current)
                {
                    <li class="page-item active"><span class="page-link">@i</span></li>
                }
                else
                {
                    <li class="page-item"><a class="page-link" href="@PageUrl(i)">@i</a></li>
                }
            }

            @if (hasNext)
            {
                <li class="page-item">
                    <a class="page-link" href="@PageUrl(current + 1)">
                        <i class="fas fa-angle-right"></i>
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link"><i class="fas fa-angle-right"></i></span>
                </li>
            }

        </ul>
    </nav>
}