@{
    ViewData["Title"] = "Rezervasyon Başarılı";
}

<section class="pt_120 pb_120">
    <div class="container">
        <div class="text-center mx-auto" style="max-width:600px">

            <div class="mb-4">
                <div style="width:100px;height:100px;border-radius:50%;background:#10b98120;display:inline-flex;align-items:center;justify-content:center">
                    <i class="fas fa-check-circle" style="font-size:60px;color:#10b981"></i>
                </div>
            </div>

            <h1 class="mb-3">Rezervasyonunuz Alındı! 🎉</h1>
            <p class="lead text-muted mb-4">
                Talebiniz başarıyla iletildi ve <strong>onay bekliyor</strong> durumunda.
            </p>

            <div class="alert alert-light border text-start p-4 mb-4">
                <h6><i class="fas fa-info-circle text-primary"></i> Sıradaki Adımlar</h6>
                <ol class="mb-0 small">
                    <li>Ekibimiz rezervasyonunuzu kısa sürede inceleyecek</li>
                    <li>Onay sonrası belirttiğiniz <strong>email adresinize</strong> bilgilendirme gönderilecek</li>
                    <li>Mailde size özel <strong>%30 indirim kuponu</strong> ve detayları bulacaksınız</li>
                    <li>Belirttiğiniz alış lokasyonundan aracınızı teslim alabilirsiniz</li>
                </ol>
            </div>

            <div class="d-flex gap-2 justify-content-center">
                <a asp-controller="Home" asp-action="Index" class="btn-style-three">
                    <i class="fas fa-home"></i> Anasayfa
                </a>
                <a asp-controller="Cars" asp-action="Index" class="btn-style-four">
                    <i class="fas fa-car"></i> Diğer Araçlar
                </a>
            </div>

        </div>
    </div>
</section>