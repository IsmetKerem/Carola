@model List<Carola.DtoLayer.SliderDtos.ResultSliderDto>
@{
    ViewData["Title"] = "Slider Yönetimi";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="data-card">
    <div class="data-card-header">
        <h5 class="data-card-title">Slider'lar (@Model.Count)</h5>
        <a asp-action="Create" class="btn-primary-action">
            <i class="bi bi-plus-lg"></i> Yeni Slider
        </a>
    </div>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Görsel</th>
                    <th>Başlık</th>
                    <th>Açıklama</th>
                    <th>Durum</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.SliderId</td>
                        <td>
                            <img src="@item.Image" alt="slider"
                                 onerror="this.style.display='none'"
                                 style="width:60px;height:40px;object-fit:cover;border-radius:6px;background:#f3f4f6" />
                        </td>
                        <td><strong>@item.Title</strong></td>
                        <td class="text-muted small" style="max-width:350px">@item.Description</td>
                        <td>
                            <span class="status-badge @(item.Status ? "active" : "inactive")">
                                @(item.Status ? "Aktif" : "Pasif")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Update" asp-route-id="@item.SliderId" class="btn-icon text-primary" title="Düzenle">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.SliderId" class="btn-icon text-danger" title="Sil"
                               onclick="return confirm('Bu slider ı silmek istediğinize emin misiniz?')">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>