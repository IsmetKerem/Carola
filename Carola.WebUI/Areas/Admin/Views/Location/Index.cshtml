@model List<Carola.DtoLayer.LocationDtos.ResultLocationDto>
@{
    ViewData["Title"] = "Lokasyon Yönetimi";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="data-card">
    <div class="data-card-header">
        <h5 class="data-card-title">Lokasyonlar (@Model.Count)</h5>
        <a asp-action="Create" class="btn-primary-action">
            <i class="bi bi-plus-lg"></i> Yeni Lokasyon
        </a>
    </div>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Lokasyon Adı</th>
                    <th>Şehir</th>
                    <th>Yetkili</th>
                    <th>Adres</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.LocationId</td>
                        <td><strong>@item.LocationName</strong></td>
                        <td>@item.City</td>
                        <td>@item.AuthorizedPerson</td>
                        <td class="text-muted small">@item.Address</td>
                        <td class="text-end">
                            <a asp-action="Update" asp-route-id="@item.LocationId" class="btn-icon text-primary" title="Düzenle">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.LocationId" class="btn-icon text-danger" title="Sil"
                               onclick="return confirm('Bu lokasyonu silmek istediğinize emin misiniz?')">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>