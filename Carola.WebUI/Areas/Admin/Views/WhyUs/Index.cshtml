@model List<Carola.DtoLayer.WhyUsDtos.ResultWhyUsDto>
@{
    ViewData["Title"] = "We Are The Best - Yönetimi";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="data-card">
    <div class="data-card-header">
        <h5 class="data-card-title">"Bizi Tercih Edin" Maddeleri (@Model.Count)</h5>
        <a asp-action="Create" class="btn-primary-action">
            <i class="bi bi-plus-lg"></i> Yeni Madde
        </a>
    </div>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>İkon</th>
                    <th>Başlık</th>
                    <th>Açıklama</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.WhyUsId</td>
                        <td>
                            <img src="@item.IconUrl" alt="icon"
                                 onerror="this.style.display='none'"
                                 style="width:36px;height:36px;object-fit:contain" />
                        </td>
                        <td><strong>@item.Title</strong></td>
                        <td class="text-muted small" style="max-width:400px">@item.Description</td>
                        <td class="text-end">
                            <a asp-action="Update" asp-route-id="@item.WhyUsId" class="btn-icon text-primary" title="Düzenle">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.WhyUsId" class="btn-icon text-danger" title="Sil"
                               onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>