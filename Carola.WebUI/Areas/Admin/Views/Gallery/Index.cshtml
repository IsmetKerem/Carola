@model List<Carola.DtoLayer.GalleryDtos.ResultGalleryDto>
@{
    ViewData["Title"] = "Galeri Yönetimi";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="data-card">
    <div class="data-card-header">
        <h5 class="data-card-title">Galeri Görselleri (@Model.Count)</h5>
        <a asp-action="Create" class="btn-primary-action">
            <i class="bi bi-plus-lg"></i> Yeni Görsel
        </a>
    </div>

    <div class="p-4">
        @if (!Model.Any())
        {
            <p class="text-muted text-center py-5 mb-0">Henüz görsel eklenmemiş.</p>
        }
        else
        {
            <div class="row g-3">
                @foreach (var item in Model)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <div class="position-relative" style="border:1px solid #e5e7eb;border-radius:10px;overflow:hidden">
                            <img src="@item.ImageUrl" alt="gallery"
                                 onerror="this.src='https://via.placeholder.com/300x200?text=Görsel+Yok'"
                                 style="width:100%;height:160px;object-fit:cover" />
                            <div class="p-2 d-flex justify-content-between align-items-center">
                                <small class="text-muted">#@item.GalleryId</small>
                                <div>
                                    <a asp-action="Update" asp-route-id="@item.GalleryId" class="btn-icon text-primary" title="Düzenle">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.GalleryId" class="btn-icon text-danger" title="Sil"
                                       onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>