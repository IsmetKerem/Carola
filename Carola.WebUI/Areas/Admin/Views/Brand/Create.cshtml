@model Carola.DtoLayer.BrandDtos.CreateBrandDto
@{
    ViewData["Title"] = "Yeni Marka Ekle";
}

<div class="form-card">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" class="alert alert-danger" style="@(ViewData.ModelState.IsValid ? "display:none" : "")"></div>

        <div class="mb-3">
            <label asp-for="BrandName" class="form-label">Marka Adı</label>
            <input asp-for="BrandName" class="form-control" placeholder="Örn: BMW" />
            <span asp-validation-for="BrandName" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="LogoUrl" class="form-label">Logo URL</label>
            <input asp-for="LogoUrl" class="form-control" placeholder="/assets/images/brands/bmw.png" />
            <span asp-validation-for="LogoUrl" class="text-danger small"></span>
        </div>

        <div class="form-check mb-4">
            <input asp-for="Status" class="form-check-input" />
            <label asp-for="Status" class="form-check-label">Anasayfada öne çıkan marka olarak göster</label>
        </div>

        <button type="submit" class="btn-primary-action">
            <i class="bi bi-check-lg"></i> Kaydet
        </button>
        <a asp-action="Index" class="btn btn-link text-decoration-none">İptal</a>
    </form>
</div>