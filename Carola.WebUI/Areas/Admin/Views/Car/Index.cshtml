@model List<Carola.DtoLayer.CarDtos.ResultCarDto>
@{
    ViewData["Title"] = "Araç Yönetimi";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="data-card">
    <div class="data-card-header">
        <h5 class="data-card-title">Araçlar (@Model.Count)</h5>
        <a asp-action="Create" class="btn-primary-action">
            <i class="bi bi-plus-lg"></i> Yeni Araç
        </a>
    </div>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Görsel</th>
                    <th>Marka / Model</th>
                    <th>Kategori</th>
                    <th>Plaka</th>
                    <th>Yıl</th>
                    <th>Yakıt</th>
                    <th>Vites</th>
                    <th>Günlük Fiyat</th>
                    <th>Durum</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="11" class="text-center text-muted py-4">Henüz araç eklenmemiş.</td></tr>
                }
                @foreach (var car in Model)
                {
                    <tr>
                        <td>#@car.CarId</td>
                        <td>
                            <img src="@car.ImageUrl" alt="@car.Model"
                                 onerror="this.style.display='none'"
                                 style="width:80px;height:50px;object-fit:cover;border-radius:6px;background:#f3f4f6" />
                        </td>
                        <td><strong>@car.BrandName @car.Model</strong></td>
                        <td><span class="text-muted">@car.CategoryName</span></td>
                        <td>@car.PlateNumber</td>
                        <td>@car.ModelYear</td>
                        <td><small>@car.FuelType</small></td>
                        <td><small>@car.TransmissionType</small></td>
                        <td><strong>@car.DailyPrice.ToString("N0") ₺</strong></td>
                        <td>
                            <span class="status-badge @(car.IsAvailable ? "active" : "inactive")">
                                @(car.IsAvailable ? "Aktif" : "Pasif")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Update" asp-route-id="@car.CarId" class="btn-icon text-primary" title="Düzenle">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@car.CarId" class="btn-icon text-danger" title="Sil"
                               onclick="return confirm('Bu aracı silmek istediğinize emin misiniz?')">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>