@model Carola.DtoLayer.CarDtos.CreateCarDto
@{
    ViewData["Title"] = "Yeni Araç Ekle";
    var brands = ViewBag.Brands as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
    var categories = ViewBag.Categories as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
    var fuelTypes = ViewBag.FuelTypes as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
    var transmissionTypes = ViewBag.TransmissionTypes as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
}

<div class="form-card" style="max-width:900px">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" class="alert alert-danger" style="@(ViewData.ModelState.IsValid ? "display:none" : "")"></div>

        <h6 class="text-muted text-uppercase small mb-3" style="letter-spacing:0.5px">Genel Bilgiler</h6>
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <label asp-for="BrandId" class="form-label">Marka</label>
                <select asp-for="BrandId" asp-items="brands" class="form-select">
                    <option value="">-- Marka Seçin --</option>
                </select>
                <span asp-validation-for="BrandId" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="CategoryId" class="form-label">Kategori</label>
                <select asp-for="CategoryId" asp-items="categories" class="form-select">
                    <option value="">-- Kategori Seçin --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Model" class="form-label">Model</label>
                <input asp-for="Model" class="form-control" placeholder="Örn: 320i" />
                <span asp-validation-for="Model" class="text-danger small"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="ModelYear" class="form-label">Model Yılı</label>
                <input asp-for="ModelYear" type="number" class="form-control" min="2000" max="2030" placeholder="2024" />
                <span asp-validation-for="ModelYear" class="text-danger small"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="PlateNumber" class="form-label">Plaka</label>
                <input asp-for="PlateNumber" class="form-control" placeholder="34 AB 1234" />
                <span asp-validation-for="PlateNumber" class="text-danger small"></span>
            </div>
        </div>

        <h6 class="text-muted text-uppercase small mb-3" style="letter-spacing:0.5px">Teknik Özellikler</h6>
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <label asp-for="SeatCount" class="form-label">Koltuk Sayısı</label>
                <input asp-for="SeatCount" type="number" class="form-control" min="1" max="20" placeholder="5" />
                <span asp-validation-for="SeatCount" class="text-danger small"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="LuggageCapacity" class="form-label">Bagaj (Bavul)</label>
                <input asp-for="LuggageCapacity" type="number" class="form-control" min="0" max="20" placeholder="3" />
                <span asp-validation-for="LuggageCapacity" class="text-danger small"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="Mileage" class="form-label">Kilometre</label>
                <input asp-for="Mileage" type="number" class="form-control" min="0" placeholder="15000" />
                <span asp-validation-for="Mileage" class="text-danger small"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="DailyPrice" class="form-label">Günlük Fiyat (₺)</label>
                <input asp-for="DailyPrice" type="number" step="0.01" class="form-control" placeholder="2500.00" />
                <span asp-validation-for="DailyPrice" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="FuelType" class="form-label">Yakıt Tipi</label>
                <select asp-for="FuelType" asp-items="fuelTypes" class="form-select">
                    <option value="">-- Seçin --</option>
                </select>
                <span asp-validation-for="FuelType" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="TransmissionType" class="form-label">Vites Tipi</label>
                <select asp-for="TransmissionType" asp-items="transmissionTypes" class="form-select">
                    <option value="">-- Seçin --</option>
                </select>
                <span asp-validation-for="TransmissionType" class="text-danger small"></span>
            </div>
        </div>

        <h6 class="text-muted text-uppercase small mb-3" style="letter-spacing:0.5px">Görsel & Açıklama</h6>
        <div class="row g-3 mb-4">
            <div class="col-12">
                <label asp-for="ImageUrl" class="form-label">Görsel URL</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="/assets/images/cars/bmw-320i.jpg" />
                <span asp-validation-for="ImageUrl" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label asp-for="Description" class="form-label">Açıklama</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Aracın detaylı açıklaması..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <div class="form-check">
                    <input asp-for="IsAvailable" class="form-check-input" />
                    <label asp-for="IsAvailable" class="form-check-label">
                        Araç aktif (sitede gösterilsin)
                    </label>
                </div>
            </div>
        </div>

        <div class="border-top pt-4">
            <button type="submit" class="btn-primary-action">
                <i class="bi bi-check-lg"></i> Kaydet
            </button>
            <a asp-action="Index" class="btn btn-link text-decoration-none">İptal</a>
        </div>
    </form>
</div>