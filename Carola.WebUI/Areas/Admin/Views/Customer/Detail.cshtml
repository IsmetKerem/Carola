@model Carola.DtoLayer.CustomerDtos.GetByIdCustomerDto
@{
    ViewData["Title"] = $"Müşteri #{Model.CustomerId}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">@Model.FirstName @Model.LastName</h4>
    <a asp-action="Index" class="btn btn-link text-decoration-none">
        <i class="bi bi-arrow-left"></i> Listeye Dön
    </a>
</div>

<div class="row g-4">

    <div class="col-lg-7">
        <div class="data-card">
            <div class="data-card-header">
                <h5 class="data-card-title">Müşteri Bilgileri</h5>
            </div>
            <div class="p-4">

                <h6 class="text-muted text-uppercase small mb-3" style="letter-spacing:0.5px">Kişisel</h6>
                <div class="row mb-2">
                    <div class="col-sm-4 text-muted">Ad:</div>
                    <div class="col-sm-8"><strong>@Model.FirstName</strong></div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-4 text-muted">Soyad:</div>
                    <div class="col-sm-8"><strong>@Model.LastName</strong></div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-4 text-muted">Doğum Tarihi:</div>
                    <div class="col-sm-8">@Model.BirthDate.ToString("dd MMMM yyyy")</div>
                </div>

                <hr/>
                <h6 class="text-muted text-uppercase small mb-3" style="letter-spacing:0.5px">İletişim</h6>
                <div class="row mb-2">
                    <div class="col-sm-4 text-muted">Email:</div>
                    <div class="col-sm-8"><a href="mailto:@Model.Email">@Model.Email</a></div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-4 text-muted">Telefon:</div>
                    <div class="col-sm-8"><a href="tel:@Model.Phone">@Model.Phone</a></div>
                </div>

                <hr/>
                <h6 class="text-muted text-uppercase small mb-3" style="letter-spacing:0.5px">Ehliyet Bilgileri</h6>
                <div class="row mb-2">
                    <div class="col-sm-4 text-muted">Ehliyet No:</div>
                    <div class="col-sm-8">@Model.DriverLicenseNumber</div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-4 text-muted">Ehliyet Sınıfı:</div>
                    <div class="col-sm-8"><span class="status-badge active">@Model.DriverLicenseClass</span></div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-4 text-muted">Veriliş Tarihi:</div>
                    <div class="col-sm-8">@Model.DriverLicenseIssueDate.ToString("dd MMMM yyyy")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="data-card">
            <div class="data-card-header">
                <h5 class="data-card-title">Yüklenen Ehliyet Görseli</h5>
            </div>
            <div class="p-4 text-center">
                @if (!string.IsNullOrWhiteSpace(Model.LicenseImageUrl))
                {
                    <img src="@Model.LicenseImageUrl" alt="Ehliyet"
                         onerror="this.src='https://via.placeholder.com/400x250?text=Görsel+Bulunamadı'"
                         style="max-width:100%;border-radius:8px;border:1px solid #e5e7eb" />
                    <div class="mt-3">
                        <a href="@Model.LicenseImageUrl" target="_blank" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-arrows-fullscreen"></i> Tam Boyut
                        </a>
                    </div>
                }
                else
                {
                    <div class="text-muted py-5">
                        <i class="bi bi-image" style="font-size:48px;opacity:0.3"></i>
                        <p class="mt-2 mb-0">Ehliyet görseli yüklenmemiş.</p>
                    </div>
                }
            </div>
        </div>
    </div>

</div>